    "example": "node examples/basic.js",
    "example:stream": "node examples/streaming.js",
    "example:history": "node examples/history.js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "thesys",
    "ai",
    "chat",
    "streaming",
    "sdk",
    "claude"
