{
  "name": "thesys-sdk",
  "version": "1.0.0",
  "description": "A professional Node.js SDK for the Thesys AI Chat API with streaming, conversation history, and async iterator support.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
